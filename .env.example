# Cloudflare Stream Live Input RTMP URL
# 
# From the Cloudflare dashboard: Stream → Live Inputs → Your Input
# The Connection Info page shows two parts:
#   URL:  rtmps://live.cloudflare.com:443/live/
#   Key:  your-unique-stream-key
#
# The full STREAM_URL is the URL + Key concatenated:
#   STREAM_URL=rtmps://live.cloudflare.com:443/live/YOUR_STREAM_KEY_HERE
STREAM_URL=rtmps://live.cloudflare.com:443/live/YOUR_STREAM_KEY_HERE

# Cloudflare Stream playback URL (for the /watch page in a browser)
#
# This should be a web playback URL, NOT the "RTMPS Playback Key".
# The RTMPS Playback Key is for pulling the stream into tools like OBS/VLC.
#
# Use one of these from the Stream dashboard:
#   - iframe embed URL:  https://iframe.cloudflarestream.com/YOUR_LIVE_INPUT_ID
#   - HLS manifest URL:  https://customer-xxx.cloudflarestream.com/YOUR_LIVE_INPUT_ID/manifest/video.m3u8
#   - Customer hostname: https://customer-xxx.cloudflarestream.com/YOUR_LIVE_INPUT_ID
#
# Any URL where the Live Input ID is the last path segment works.
# The watch page extracts the ID and builds the iframe embed automatically.
STREAM_PLAYBACK_URL=https://iframe.cloudflarestream.com/YOUR_LIVE_INPUT_ID

# RTMP Playback URL (for viewing the raw feed with low latency)
#
# From the Cloudflare dashboard: Stream → Live Inputs → Your Input
# This is the "RTMPS Playback Key" — used to pull/watch the stream.
# NOT the same as the ingest STREAM_URL above.
#
# Used by the streaming page to show the exact ffplay command with a copy button.
RTMP_PLAYBACK_URL=rtmps://live.cloudflare.com:443/live/YOUR_PLAYBACK_KEY

# Container port (mapped to localhost)
CONTAINER_PORT=8788
