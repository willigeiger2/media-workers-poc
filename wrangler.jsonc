{
	"compatibility_date": "2026-05-26",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "media-workers-poc",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"vars": {
		"STREAM_PLAYBACK_URL": "",
		"RTMP_PLAYBACK_URL": ""
	}
	// TODO: Add container binding for production deployment.
	// See README.md for details.
}
