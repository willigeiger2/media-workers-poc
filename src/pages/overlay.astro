---
import Layout from "../layouts/Layout.astro";
import StreamingInterface from "../components/StreamingInterface.astro";

const howItWorksSteps = [
  "Click <strong>Start Streaming</strong> to capture your webcam",
  "Browser sends a JSON config message to select the <code>overlay</code> preset",
  "WebSocket binary chunks go to the Go container",
  "Container pipes chunks to ffmpeg with <code>filter_complex</code>",
  "ffmpeg composites the Cloudflare logo (top-right) and outputs RTMP"
];
---

<Layout title="Media Workers PoC — Overlay">
  <StreamingInterface
    title="WebSocket Video with Overlay"
    description="Capture webcam video and composite a Cloudflare logo overlay using ffmpeg filter_complex. The overlay is rendered in the container before sending to Cloudflare Stream."
    preset="overlay"
    showOverlayPreview={true}
    howItWorksSteps={howItWorksSteps}
  />
</Layout>
