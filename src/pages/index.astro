---
import Layout from "../layouts/Layout.astro";
import StreamingInterface from "../components/StreamingInterface.astro";

const howItWorksSteps = [
  "Click <strong>Start Streaming</strong> to capture your webcam",
  "Video chunks are sent via WebSocket to the Worker",
  "Worker proxies chunks to the Go container",
  "Container pipes chunks to ffmpeg",
  "ffmpeg transcodes to H.264 and sends RTMP to Cloudflare Stream"
];
---

<Layout title="Media Workers PoC — Stream">
  <StreamingInterface
    title="WebSocket Video Pass-Through"
    description="Capture webcam video, send it over a WebSocket to a Cloudflare Container running ffmpeg, and output to a Cloudflare Stream Live Input."
    preset="passthrough"
    howItWorksSteps={howItWorksSteps}
  />
</Layout>
